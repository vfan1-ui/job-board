{
    "version": 2,
    "builds": [
        {
            "src": "supabase/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "supabase/**"
                ]
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "supabase/index.js"
        },
        {
            "src": "/",
            "dest": "public/home.html"
        },
        {
            "src": "/(.*)",
            "dest": "public/$1"
        }
    ]
}